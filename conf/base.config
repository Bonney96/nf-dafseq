// Per-process resource defaults, selected by process `label`.
// Conservative defaults that work for the targeted (small-region) DAF-seq data.

process {
    cpus   = 2
    memory = 8.GB
    time   = 2.h

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 1

    withLabel: process_low {
        cpus   = 2
        memory = 8.GB
        time   = 1.h
    }
    withLabel: process_medium {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }
    withLabel: process_high {
        // DAF-QC-SMK runs snakemake locally with --cores ${task.cpus}; give it room.
        cpus   = 16
        memory = 32.GB
        time   = 8.h
    }
}
