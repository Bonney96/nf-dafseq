// SLURM executor profile for this cluster (mirrors the old slurm/config.yaml:
// partition general-cpu, generous job concurrency). Activate with `-profile slurm`.

process {
    executor = 'slurm'
    queue    = 'general-cpu'
}

executor {
    queueSize           = 30
    submitRateLimit     = '50/1min'
}

// Latency tolerance for shared-filesystem staging, matching the old profile's latency-wait.
process.maxRetries = 2
