// WashU RIS in-house profile: Lmod modules + SLURM, no container engine.
// Activate with `-profile washu`. Because no container engine is enabled here, the
// `container` directives in modules/local/*.nf are inert and tools come from `module load`.
// Mirrors the old slurm/config.yaml (partition general-cpu, generous job concurrency).

params {
    // Restore the on-cluster defaults (the portable defaults point inside the containers).
    ref          = '/storage2/fs1/dspencer/Active/spencerlab/refdata/hg38/sequence/hg38_mgi_patch.fa'
    dafqc_repo   = '/storage2/fs1/dspencer/Active/spencerlab/mohamed/projects/daf-seq/DAF-QC-SMK'
    // Persistent location for the snakemake-managed conda envs so they build once, not per task.
    conda_prefix = "${projectDir}/.snakemake-conda-envs"
}

process {
    executor = 'slurm'
    queue    = 'general-cpu'

    // Tools come from Lmod here (containers are not used under this profile).
    withName: 'DAFQC_SMK' {
        beforeScript = 'module load pixi'
        // First job builds the shared snakemake conda envs; concurrent builds into one
        // SNAKEMAKE_CONDA_PREFIX can race/corrupt. Serialize on the cluster.
        maxForks = 1
    }
    withName: 'MINIMAP_ALIGN|MARK_DUPLICATES|PHASE_READS' {
        beforeScript = 'module load labtools'
    }

    // Latency tolerance for shared-filesystem staging, matching the old profile's latency-wait.
    maxRetries = 2
}

executor {
    queueSize       = 30
    submitRateLimit = '50/1min'
}
