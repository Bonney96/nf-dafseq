// nf-dafseq : Nextflow port of the lab DAF-seq workflow
// Lightweight DSL2. Tools ship as containers (see containers/): select an engine with
// `-profile docker|singularity|apptainer`. The `washu` profile preserves the in-house
// Lmod `module load` + SLURM path (containers inert there).

nextflow.enable.dsl = 2

manifest {
    name            = 'nf-dafseq'
    author          = 'Spencer Lab'
    description      = 'DAF-seq processing: align -> QC/decorate (DAF-QC-SMK) -> dedup -> phase'
    mainScript       = 'main.nf'
    nextflowVersion = '>=24.04.0'
    version         = '0.1.0'
}

params {
    // --- Inputs / outputs ---
    input        = "${projectDir}/assets/samplesheet.tsv"   // TSV: sample, fastq, regions, phase_type, phase_value
    outdir       = "results"

    // --- Reference (REQUIRED) ---
    // No default: pass `--ref /path/to/genome.fa`. The washu profile restores the cluster default.
    ref          = null

    // --- Wrapped Snakemake core (DAF-QC-SMK) ---
    // Defaults point INSIDE the nf-dafseq-dafqc container (repo + prebuilt conda envs baked in).
    // The washu profile overrides these to the on-cluster checkout + persistent prefix.
    dafqc_repo   = '/opt/DAF-QC-SMK'
    conda_prefix = '/opt/snakemake-conda-envs'

    // --- DAF-QC-SMK tunables (passed through to its config.yaml) ---
    platform               = 'ont'
    is_fastq               = false   // we feed pre-aligned BAMs from MINIMAP_ALIGN
    chimera_cutoff         = 0.9
    min_deamination_count  = 50
    end_tolerance          = 30
    decorated_samplesize   = 5000
    benchmark              = false

    // --- Phasing tunable ---
    del_overlap_frac       = 0.66
}

profiles {
    // --- software / container engines (pick one) ---
    docker {
        docker.enabled      = true
        docker.runOptions   = '-u $(id -u):$(id -g)'
        singularity.enabled = false
        apptainer.enabled   = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        apptainer.enabled      = false
    }
    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        docker.enabled       = false
        singularity.enabled  = false
    }

    // --- execution ---
    local {
        process.executor = 'local'
    }

    // --- WashU RIS in-house: Lmod modules + SLURM, no container engine ---
    washu {
        includeConfig 'conf/washu.config'
    }

    // --- minimal wiring/stub check (no tools or data needed) ---
    test {
        params.input = "${projectDir}/assets/samplesheet.tsv"
    }
}

includeConfig 'conf/base.config'

// Reports
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt";      overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.html";       overwrite = true }
