// nf-dafseq : Nextflow port of the lab DAF-seq workflow
// Lightweight DSL2. Dependencies are provided by `module load` (labtools) and `pixi`
// (for the wrapped DAF-QC-SMK Snakemake), not by Nextflow-managed conda/containers.

nextflow.enable.dsl = 2

manifest {
    name            = 'nf-dafseq'
    author          = 'Spencer Lab'
    description      = 'DAF-seq processing: align -> QC/decorate (DAF-QC-SMK) -> dedup -> phase'
    mainScript       = 'main.nf'
    nextflowVersion = '>=24.04.0'
    version         = '0.1.0'
}

params {
    // --- Inputs / outputs ---
    input        = "${projectDir}/assets/samplesheet.tsv"   // TSV: sample, fastq, regions, phase_type, phase_value
    outdir       = "results"

    // --- Reference ---
    ref          = '/storage2/fs1/dspencer/Active/spencerlab/refdata/hg38/sequence/hg38_mgi_patch.fa'

    // --- Wrapped Snakemake core (DAF-QC-SMK) ---
    // Path to the cloned DAF-QC-SMK repo (contains pixi.toml + workflow/Snakefile).
    // TODO: move this to a shared, non-personal path and update the default.
    dafqc_repo   = '/storage2/fs1/dspencer/Active/spencerlab/mohamed/projects/daf-seq/DAF-QC-SMK'
    // Persistent location for the snakemake-managed conda envs so they build once, not per task.
    conda_prefix = "${projectDir}/.snakemake-conda-envs"

    // --- DAF-QC-SMK tunables (passed through to its config.yaml) ---
    platform               = 'ont'
    is_fastq               = false   // we feed pre-aligned BAMs from MINIMAP_ALIGN
    chimera_cutoff         = 0.9
    min_deamination_count  = 50
    end_tolerance          = 30
    decorated_samplesize   = 5000
    benchmark              = false

    // --- Phasing tunable ---
    del_overlap_frac       = 0.66
}

profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        includeConfig 'conf/slurm.config'
    }
    test {
        params.input = "${projectDir}/assets/samplesheet.tsv"
    }
}

includeConfig 'conf/base.config'

// Reports
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt";      overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.html";       overwrite = true }
